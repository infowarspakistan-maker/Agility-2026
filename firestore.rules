rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'almalikaewan@gmail.com'
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
      ) || isAdmin();
    }

    // Admin Markers (Read only by system/admins)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && request.auth.token.email == 'almalikaewan@gmail.com';
    }

    // Travel Packages
    match /packages/{packageId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if (isSignedIn() && isOwner(resource.data.userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['passengers', 'notes', 'status']) &&
        request.resource.data.status == 'cancelled' // User can only cancel
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // Visa Requests
    match /visaRequests/{requestId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.userId));
    }

    // Chat Sessions
    match /chatSessions/{sessionId} {
      allow read, write: if isSignedIn() && (isOwner(sessionId) || isAdmin());
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (isOwner(sessionId) || isAdmin());
      }
    }

    // AI Logs
    match /aiLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // Settings
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Slides
    match /slides/{slideId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
